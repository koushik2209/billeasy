# Claude API key — get from platform.anthropic.com
ANTHROPIC_API_KEY=

# Platform details
PLATFORM_NAME=BilledUp
PLATFORM_TAGLINE=Bill smarter. Grow faster.
PLATFORM_SUPPORT_PHONE=+91 99999 99999

# Database (REQUIRED — no fallback)
# Local:      sqlite:///billedup.db
# Production: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///billedup.db

# App settings
DEBUG=True
PORT=5000

# Meta WhatsApp Cloud API (Graph API v22+)
# App → WhatsApp → API Setup — Phone number ID & access token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Webhook verification (Meta "Verify token" when you register the callback URL)
VERIFY_TOKEN=

# Public base URL for PDF/document links (HTTPS, same host as webhook in production)
BASE_URL=

# Optional: recipient for whatsapp_client.send_test_message()
WHATSAPP_TEST_TO=
